# Copia este archivo a .env y reemplaza con tus credenciales
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# GitHub Personal Access Token (Settings > Developer settings > Personal access tokens)
GITHUB_TOKEN=ghp_your_github_token_here

# Opcional: Organización de GitHub (dejar vacío para usuarios individuales)
GITHUB_ORG=your-org-name
